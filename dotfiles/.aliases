alias ls='ls -G'
alias ll='ls -l'
alias la='ls -A'
alias l='ls -CF'

alias cabal-install='cabal install --overwrite-policy=always --install-method=copy'
alias cabal-repl='cabal repl --repl-options="-fexternal-interpreter -prof"'
alias cabal-test='cabal test -O0 --enable-tests --test-show-details=direct'
alias ghcid='ghciwatch --clear --no-interrupt-reloads --error-file ghcid.txt'

alias ga='git add'
alias gb='git branch'
alias gl='git log --oneline --graph --decorate --all'
alias gs='git status'
alias gcam='git commit --amend --no-edit'
alias gcb='git switch'
alias gci='git commit'
alias gco='git restore'
alias gcp='git cherry-pick'
alias gdi='git diff'
alias gsh='git show'
alias pull='git pull'
alias push='git push'
alias rebase='git rebase'
alias stash='git stash'

alias py='uv run python'
alias pip='uv run pip'

alias codex='npx @openai/codex'

function n()
{
    if [ "$#" -eq 0 ]; then
        command nvim .;
    else
        command nvim "$@";
    fi
}
