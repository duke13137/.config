{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "permission": {
    "read": {
      "**/.envrc": "deny"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    }
  },
  "mcp": {
    "nvim": {
      "type": "local",
      "command": ["nvim-mcp", "--connect", "auto"],
      "enabled": true
    },
    "clojure": {
      "type": "local",
      "command": [
        "bash",
        "-c",
        "echo 47888 > .nrepl-port; clojure -M:repl:repl-mcp"
      ],
      "timeout": 60000,
      "enabled": true
    }
  }
}
