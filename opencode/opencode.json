{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "permission": {
    "bash": "ask",
    "read": {
      ".envrc": "deny"
    },
    "edit": {
      "*": "ask",
      ".": "allow"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    }
  },
  "mcp": {
    "nvim": {
      "type": "local",
      "command": ["nvim-mcp", "--connect", "auto"],
      "enabled": true
    }
  }
}
