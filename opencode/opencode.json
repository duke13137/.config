{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "permission": {
    "read": {
      "*": "deny",
      ".envrc": "deny",
      "~/dev/**": "allow"
    },
    "bash": {
      "*": "ask",
      "rm *": "deny",
      "git *": "ask",
      "grep *": "allow"
    },
    "edit": {
      "*": "ask",
      ".": "allow"
    },
    "external_directory": {
      "/private/tmp/**": "allow"
    }
  },
  "mcp": {
    "nvim": {
      "type": "local",
      "command": ["nvim-mcp", "--connect", "auto"],
      "enabled": true
    }
  }
}
