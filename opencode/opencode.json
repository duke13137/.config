{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "permission": {
    "read": {
      "**/.envrc": "deny"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    }
  },
  "mcp": {
    "nvim": {
      "type": "local",
      "command": ["nvim-mcp", "--connect", "auto"],
      "enabled": true
    }
  }
}
