{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "plugin": ["context-mode", "./plugins/revdiff-plan-review.ts"],
  "mcp": {
    "nvim": {
      "type": "local",
      "command": ["nvim-mcp", "--connect", "auto"],
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "**/.envrc": "deny"
    },
    "external_directory": {
      "~/config/opencode/": "allow",
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    }
  }
}
